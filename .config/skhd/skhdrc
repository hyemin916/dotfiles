# App shortcuts
# lalt + lcmd + lctrl + lshift - a: open -a 'Arc'
lalt + ctrl - b: open -a 'Dia'
lalt + ctrl - l: open -a 'Things3'
lalt + ctrl - f: open -a 'Finder'
lalt + ctrl - g: open -a 'Google Chrome'
lalt + ctrl - i: open -a 'IntelliJ IDEA Ultimate'
lalt + ctrl - m: open -a 'Mail'
lalt + ctrl - o: open -a 'Obsidian'
lalt + ctrl - p: open -a 'Preview'
lalt + ctrl - s: open -a 'Slack'
lalt + ctrl - t: open -a 'Ghostty'
lalt + ctrl - k: open -a 'KakaoTalk'

# focus window
lalt - h : yabai -m window --focus west
lalt - l : yabai -m window --focus east
lalt - j : yabai -m window --focus north
lalt - k : yabai -m window --focus south

lalt - c : yabai -m window --toggle float --grid 4:4:1:1:2:2



